<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:semi="https://irihi.tech/semi"
             x:Class="PVZRHTools.App"
             xmlns:viewModels="clr-namespace:PVZRHTools.ViewModels"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="ButtonGradientBorderBrush">
                        <GradientStop Offset="0.0" Color="#FFA20B48" />
                        <GradientStop Offset="0.3" Color="#FF71168A" />
                        <GradientStop Offset="0.6" Color="#FF46259E" />
                        <GradientStop Offset="1.0" Color="#FF28348C" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="ButtonGradientBorderBrush">
                        <GradientStop Offset="0.0" Color="#FFF7A8BC" />
                        <GradientStop Offset="0.3" Color="#FFDDA0E1" />
                        <GradientStop Offset="0.6" Color="#FFBEADE9" />
                        <GradientStop Offset="1.0" Color="#FFA7B4E2" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <viewModels:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <semi:SemiTheme Locale="zh-CN" />
        <semi:UrsaSemiTheme Locale="zh-CN" />
        <semi:SemiPopupAnimations />

        <!-- 全局按钮边框渐变动画：为所有按钮的 ContentPresenter 添加 BorderBrush 过渡 -->
        <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <!-- 全局按钮边框渐变动画：鼠标悬停时切换为渐变边框 -->
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>

        <!-- TextBox 边框渐变动画 -->
        <Style Selector="TextBox /template/ Border#PART_ContentPresenterBorder">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_ContentPresenterBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>

        <!-- CardCheckBox 卡片边框渐变动画 -->
        <Style Selector="CheckBox /template/ Border#RootBorder">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <!-- 未选中状态：设置透明初始边框 + 悬停渐变（避免覆盖选中状态的主题边框色） -->
        <Style Selector="CheckBox:not(:checked):not(:indeterminate) /template/ Border#RootBorder">
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="CheckBox:not(:checked):not(:indeterminate):pointerover /template/ Border#RootBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>

        <!-- ComboBox 边框渐变动画 -->
        <Style Selector="ComboBox">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>

        <!-- MultiComboBox 边框渐变动画 -->
        <Style Selector="u|MultiComboBox">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="u|MultiComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>

        <!-- NavMenuItem 边框渐变动画：在控件级别设 BorderBrush，由 TemplateBinding 传播到模板内 Border -->
        <Style Selector="u|NavMenuItem">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="u|NavMenuItem:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonGradientBorderBrush}" />
        </Style>
        <Style Selector="u|NavMenuItem /template/ Border#PART_Border">
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Theme" Value="{DynamicResource CardCheckBox}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="u|Divider">
            <Setter Property="Margin" Value="20,0,20,0" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate x:DataType="sys:String">
                        <TextBlock Text="{Binding }"
                                   Classes="H6"
                                   Theme="{DynamicResource TitleTextBlock}"
                                   Foreground="{DynamicResource SemiViolet5}" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="WrapPanel> Border">
            <Setter Property="Theme" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="5" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiAIGeneral3}" />
        </Style>
    </Application.Styles>
</Application>