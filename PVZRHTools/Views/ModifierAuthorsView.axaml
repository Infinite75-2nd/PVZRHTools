<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:PVZRHTools.ViewModels"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:CompileBindings="True"
             x:DataType="vm:ModifierAuthorsViewModel"
             x:Class="PVZRHTools.Views.ModifierAuthorsView">
    <StackPanel Orientation="Vertical" Spacing="10">
        <u:Divider Content="修改器作者"/>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Infinite75"
                       VerticalAlignment="Center"
                       Classes="H6"
                       Theme="{StaticResource TitleTextBlock}"
                       Foreground="{DynamicResource SemiColorAIGeneralActive}" />
            <u:IconButton Icon="{DynamicResource SemiIconHomeStroked}"
                          Command="{Binding OpenSpaceInf75Command}"
                          IsEnabled="True" />
            <u:IconButton Icon="{DynamicResource SemiIconGithubLogo}"
                          Command="{Binding OpenGithubInf75Command}"
                          IsEnabled="True" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="梧萱梦汐X"
                       VerticalAlignment="Center"
                       Classes="H6"
                       Theme="{StaticResource TitleTextBlock}"
                       Foreground="{DynamicResource SemiColorAIGeneralActive}" />
            <u:IconButton Icon="{DynamicResource SemiIconHomeStroked}"
                          Command="{Binding OpenSpaceMKHkro1Command}"
                          IsEnabled="True" />
            <u:IconButton Icon="{DynamicResource SemiIconGithubLogo}"
                          Command="{Binding OpenGithubMKHkro1Command}"
                          IsEnabled="True" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="墨染荷韵"
                       VerticalAlignment="Center"
                       Classes="H6"
                       Theme="{StaticResource TitleTextBlock}"
                       Foreground="{DynamicResource SemiColorAIGeneralActive}" />
            <u:IconButton Icon="{DynamicResource SemiIconHomeStroked}"
                          Command="{Binding OpenSpaceCarefreeSongs712Command}"
                          IsEnabled="True" />
            <u:IconButton Icon="{DynamicResource SemiIconGithubLogo}"
                          Command="{Binding OpenGithubCarefreeSongs712Command}"
                          IsEnabled="True" />
        </StackPanel>
    </StackPanel>
</UserControl>